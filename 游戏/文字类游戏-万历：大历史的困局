def print_status(gs, show_changes=False):
    print("\n" + color_text("【当前状态】", Colors.BOLD))
    print("-" * 70)
    
    print(color_text("  基础属性:", Colors.YELLOW))
    for attr, value in gs.attributes.items():
        bar = "+" * (value // 5) + "-" * (20 - value // 5)
        if value >= 60:
            color = Colors.GREEN
        elif value >= 40:
            color = Colors.YELLOW
        else:
            color = Colors.RED
        
        change_str = ""
        if show_changes and attr in gs.last_changes:
            change = gs.last_changes[attr]
            if change > 0:
                change_str = color_text(" (+" + str(change) + ")", Colors.GREEN)
            else:
                change_str = color_text(" (" + str(change) + ")", Colors.RED)
        
        print("    " + attr + ": [" + color + bar + Colors.RESET + "] " + str(value) + change_str)
    
    if gs.player_role in ["万历皇帝", "崇祯皇帝"]:
        print("\n" + color_text("  国家状态:", Colors.YELLOW))
        for stat, value in gs.imperial_stats.items():
            bar = "+" * (value // 5) + "-" * (20 - value // 5)
            if value >= 60:
                color = Colors.GREEN
            elif value >= 40:
                color = Colors.YELLOW
            else:
                color = Colors.RED
            
            change_str = ""
            if show_changes and stat in gs.last_changes:
                change = gs.last_changes[stat]
                if change > 0:
                    change_str = color_text(" (+" + str(change) + ")", Colors.GREEN)
                else:
                    change_str = color_text(" (" + str(change) + ")", Colors.RED)
            
            print("    " + stat + ": [" + color + bar + Colors.RESET + "] " + str(value) + change_str)
    
    print("\n" + color_text("  派系势力:", Colors.YELLOW))
    for faction, value in gs.factions.items():
        bar = "+" * (value // 5) + "-" * (20 - value // 5)
        if value >= 60:
            color = Colors.GREEN
        elif value >= 40:
            color = Colors.YELLOW
        else:
            color = Colors.RED
        
        change_str = ""
        if show_changes and ('faction_' + faction) in gs.last_changes:
            change = gs.last_changes['faction_' + faction]
            if change > 0:
                change_str = color_text(" (+" + str(change) + ")", Colors.GREEN)
            else:
                change_str = color_text(" (" + str(change) + ")", Colors.RED)
        
        print("    " + faction + ": [" + color + bar + Colors.RESET + "] " + str(value) + change_str)
    
    print("\n" + color_text("  内心状态:", Colors.MAGENTA))
    for state, value in gs.inner_state.items():
        bar = "+" * (value // 5) + "-" * (20 - value // 5)
        if state == '决心值':
            color = Colors.GREEN if value >= 60 else Colors.YELLOW if value >= 40 else Colors.RED
        else:
            color = Colors.RED if value >= 60 else Colors.YELLOW if value >= 40 else Colors.GREEN
        
        change_str = ""
        if show_changes and ('inner_' + state) in gs.last_changes:
            change = gs.last_changes['inner_' + state]
            if change > 0:
                change_str = color_text(" (+" + str(change) + ")", Colors.RED if state != '决心值' else Colors.GREEN)
            else:
                change_str = color_text(" (" + str(change) + ")", Colors.GREEN if state != '决心值' else Colors.RED)
        
        print("    " + state + ": [" + color + bar + Colors.RESET + "] " + str(value) + change_str)
    
    crises = gs.check_crisis()
    if crises:
        print("\n" + color_text("  ⚠️  危机警告:", Colors.RED))
        for crisis in crises:
            print("    • " + crisis)
    
    print("-" * 70)


def main():
    clear_screen()
    print_background()
    
    print_large("请选择扮演角色（影响初始属性和历史定位）：", Colors.BOLD)
    print("-" * 70)
    
    for key in RoleSystem.ROLES:
        role = RoleSystem.ROLES[key]
        role_name = role['name']
        role_desc = role['description']
        attrs = role['attributes']
        difficulty = role['difficulty_note']
        historical = role['historical_note']
        
        print(color_text(key, Colors.YELLOW) + ". " + color_text(role_name, Colors.BOLD))
        print("   " + role_desc)
        print("   " + color_text(difficulty, Colors.RED))
        print("   " + color_text("历史注：" + historical, Colors.GRAY))
        print("   初始属性 -> 技术:" + str(attrs['技术值']) + " 道德:" + str(attrs['道德值']) + 
              " 皇权:" + str(attrs['皇权值']) + " 文官:" + str(attrs['文官支持']) + 
              " 民心:" + str(attrs['民心']) + " 军力:" + str(attrs['军力']))
        print("-" * 70)
    
    print(color_text("\n⚠️  难度提示：", Colors.RED))
    print("  • 负面效果放大 1.5 倍，每个选择都有代价")
    print("  • 没有完美选项，所有决策都是两难")
    print("  • 内心状态会影响决策效果和历史走向")
    print("  • 最佳结局达成率<5%，请做好心理准备")
    print("  • 架空路线可开启不同历史线，但风险更高")
    
    role_choice = input("\n请输入角色编号（1-6）: ")
    role = RoleSystem.select_role(role_choice)
    
    if not role:
        print("无效选择，使用默认角色：万历皇帝")
        role = RoleSystem.ROLES["1"]
    
    gs = GameState(role['name'])
    gs.attributes = role['attributes'].copy()
    gs.imperial_stats = role['imperial_stats'].copy()
    gs.factions = role['factions'].copy()
    gs.inner_state = role['inner_state'].copy()
    
    for flag, value in role['flags_bonus'].items():
        gs.flags[flag] = value
    
    if role['name'] == "崇祯皇帝":
        gs.year = 1628
        gs.era = "崇祯"
    
    print("\n" + color_text("OK", Colors.GREEN) + " 您选择扮演：" + color_text(role['name'], Colors.BOLD))
    print("  游戏将从 " + str(gs.year) + "年（" + gs.era + "） 开始\n")
    
    print_status(gs)
    
    input("\n按回车键开始游戏...")
    clear_screen()
    
    print_large("=" * 70, Colors.GRAY)
    print_large("游戏开始", Colors.BOLD)
    print_large("=" * 70, Colors.GRAY)
    
    events = HistoricalEventSystem.get_events()
    start_year = gs.year
    
    for year in range(start_year, 1645):
        if gs.game_ended:
            break
            
        gs.year = year
        if year < 1573:
            gs.era = "隆庆"
        elif year < 1621:
            gs.era = "万历"
        elif year < 1628:
            gs.era = "天启"
        else:
            gs.era = "崇祯"
        
        for event_key, event_data in events.items():
            if gs.game_ended:
                break
                
            if event_data['year'] != year:
                continue
            
            if any(node['事件'] == event_key for node in gs.logic_chain):
                continue
            
            role_desc = HistoricalEventSystem.get_role_perspective(gs.player_role, event_key)
            description = role_desc if role_desc else event_data['base_description']
            
            print("\n" + color_text("-" * 70, Colors.GRAY))
            print(color_text(description, Colors.WHITE))
            
            if 'terms' in event_data:
                print("\n" + color_text("【专有名词】", Colors.CYAN))
                for term in event_data['terms']:
                    if term in TERM_DATABASE:
                        print_term(term, TERM_DATABASE[term])
            
            valid_options = []
            for idx, opt in enumerate(event_data['options'], 1):
                if opt.get('role_requirement') and gs.player_role not in opt['role_requirement']:
                    continue
                print("\n" + color_text(str(idx), Colors.YELLOW) + ". " + opt['text'])
                print("    " + color_text("后果：" + opt['consequence'], Colors.GRAY))
                print("    " + color_text("历史注：" + opt['historical_note'], Colors.GRAY))
                if 'alternate_note' in opt:
                    print("    " + color_text("架空注：" + opt['alternate_note'], Colors.BLUE))
                valid_options.append(opt)
            
            if not valid_options:
                print(color_text("  当前条件下无可用选项，跳过此事件。", Colors.GRAY))
                continue
            
            try:
                choice = int(input("\n" + color_text("请选择", Colors.BOLD) + " (输入数字): ")) - 1
                if 0 <= choice < len(valid_options):
                    selected = valid_options[choice]
                    
                    if not gs.check_logic_consistency(selected['logic_type']):
                        print("\n" + color_text("⚠️  警告", Colors.RED) + "：此选择与您之前的决策逻辑矛盾！")
                        print("历史惯性生效：文官集团质疑您的执政逻辑，改革阻力倍增。")
                        gs.update_attribute('文官支持', -20)
                        gs.update_inner_state('疑虑度', 15)
                        gs.update_inner_state('疲惫度', 10)
                    
                    power_mult = gs.get_role_power_multiplier()
                    inertia_mult = 1.0 / gs.historical_inertia
                    gs.last_changes = {}
                    
                    for attr, change in selected['base_effects'].items():
                        actual_change = int(change * power_mult * inertia_mult)
                        if attr.startswith('imperial_'):
                            gs.update_imperial_stat(attr[9:], actual_change)
                        elif attr.startswith('faction_'):
                            gs.update_faction(attr[8:], actual_change)
                        else:
                            gs.update_attribute(attr, actual_change)
                    
                    for state, change in selected.get('inner_effects', {}).items():
                        gs.update_inner_state(state, change)
                    
                    for flag, value in selected['flags'].items():
                        gs.flags[flag] = value
                    
                    gs.record_decision(event_key, selected['text'], selected['logic_type'])
                    
                    monologue = gs.get_inner_monologue(event_key, selected['logic_type'])
                    if monologue:
                        print("\n" + color_text("【内心独白】", Colors.MAGENTA))
                        print(color_text("  " + monologue, Colors.WHITE))
                    
                    print("\n" + color_text("OK", Colors.GREEN) + " 决策已记录至历史逻辑链")
                    
                    print_status(gs, show_changes=True)
                    
                    if selected.get('early_end'):
                        end_condition = selected.get('end_condition', '')
                        should_end = False
                        
                        if end_condition == 'always':
                            should_end = True
                        elif end_condition.startswith('文官支持 <'):
                            threshold = int(end_condition.split('<')[1].strip())
                            if gs.attributes['文官支持'] < threshold:
                                should_end = True
                        elif end_condition.startswith('民心 <'):
                            threshold = int(end_condition.split('<')[1].strip())
                            if gs.attributes['民心'] < threshold:
                                should_end = True
                        elif end_condition.startswith('皇权值 <'):
                            threshold = int(end_condition.split('<')[1].strip())
                            if gs.attributes['皇权值'] < threshold:
                                should_end = True
                        
                        if should_end:
                            gs.game_ended = True
                            ending = EndingSystem.get_early_ending(gs, event_key, selected['text'])
                            print(ending)
                            break
                    
                else:
                    print(color_text("无效选择，跳过此事件", Colors.GRAY))
            except ValueError:
                print(color_text("输入错误，跳过此事件", Colors.GRAY))
            except KeyboardInterrupt:
                print("\n\n" + color_text("游戏已退出。感谢您的游玩！", Colors.YELLOW))
                return
        
        if gs.attributes['文官支持'] < 30:
            gs.update_attribute('文官支持', 3)
            gs.update_inner_state('疲惫度', 5)
        if gs.attributes['民心'] < 20:
            gs.update_attribute('军力', -8)
            gs.update_inner_state('孤独感', 10)
    
    if not gs.game_ended:
        print("\n" + color_text("=" * 70, Colors.BOLD))
        print(color_text("【历史终局】1644 年，大明王朝走到了终点...", Colors.BOLD))
        print(color_text("=" * 70, Colors.BOLD))
        print()
        print(EndingSystem.get_final_ending(gs))
    
    print(color_text("=" * 70, Colors.GRAY))
    print(color_text("【逻辑链回溯】", Colors.BOLD))
    print(color_text("=" * 70, Colors.GRAY))
    
    for node in gs.logic_chain:
        if node['逻辑类型'] == '技术':
            logic_color = Colors.GREEN
        elif node['逻辑类型'] == '道德':
            logic_color = Colors.RED
        else:
            logic_color = Colors.YELLOW
        
        print(color_text(str(node['年份']), Colors.CYAN) + "年 (" + node['年号'] + ") | " + node['事件'])
        choice_text = node['选择']
        if len(choice_text) > 60:
            choice_text = choice_text[:60] + "..."
        print("  -> " + color_text(choice_text, logic_color))
        print()
    
    print(color_text("=" * 70, Colors.GRAY))
    print(color_text("感谢游玩《万历：大历史的困局》", Colors.BOLD))
    print(color_text("=" * 70, Colors.GRAY))


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n" + color_text("游戏已退出。感谢您的游玩！", Colors.YELLOW))
    except Exception as e:
        print("\n" + color_text("发生错误：" + str(e), Colors.RED))
        print("请检查代码或重新运行。")
