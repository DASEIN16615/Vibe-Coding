        self.critical_moments = 0
        self.alternate_history = False
    
    def update_attribute(self, attr, change):
        old_value = self.attributes.get(attr, 50)
        if change < 0:
            change = int(change * self.difficulty_multiplier)
        new_value = max(0, min(100, old_value + change))
        self.attributes[attr] = new_value
        self.last_changes[attr] = change
    
    def update_imperial_stat(self, stat, change):
        if stat in self.imperial_stats:
            old_value = self.imperial_stats[stat]
            if change < 0:
                change = int(change * self.difficulty_multiplier)
            new_value = max(0, min(100, old_value + change))
            self.imperial_stats[stat] = new_value
            self.last_changes[stat] = change
    
    def update_faction(self, faction, change):
        if faction in self.factions:
            old_value = self.factions[faction]
            if change < 0:
                change = int(change * self.difficulty_multiplier)
            new_value = max(0, min(100, old_value + change))
            self.factions[faction] = new_value
            self.last_changes['faction_' + faction] = change
    
    def update_inner_state(self, state, change):
        if state in self.inner_state:
            old_value = self.inner_state[state]
            new_value = max(0, min(100, old_value + change))
            self.inner_state[state] = new_value
            self.last_changes['inner_' + state] = change
    
    def record_decision(self, event, choice, logic_type):
        self.logic_chain.append({
            '年份': self.year,
            '年号': self.era,
            '事件': event,
            '选择': choice,
            '逻辑类型': logic_type,
            '状态快照': self.attributes.copy(),
            '派系快照': self.factions.copy(),
            '内心快照': self.inner_state.copy(),
            '制度危机': self.institutional_crisis
        })
        self.historical_inertia += 0.1
    
    def check_logic_consistency(self, current_logic):
        if len(self.logic_chain) < 1:
            return True
        last_decision = self.logic_chain[-1]
        if last_decision['逻辑类型'] == '技术' and current_logic == '道德':
            return False
        if len(self.logic_chain) >= 2:
            last_two = [d['逻辑类型'] for d in self.logic_chain[-2:]]
            if last_two == ['妥协', '妥协'] and current_logic == '技术':
                return False
        return True
    
    def get_role_power_multiplier(self):
        power_map = {
            '万历皇帝': 1.3,
            '崇祯皇帝': 1.1,
            '张居正': 1.1,
            '海瑞': 0.7,
            '戚继光': 0.8,
            '东林党人': 0.6
        }
        return power_map.get(self.player_role, 1.0)
    
    def check_crisis(self):
        crises = []
        if self.attributes['文官支持'] < 30:
            crises.append("文官集团集体怠政")
        if self.attributes['民心'] < 30:
            crises.append("民变四起")
        if self.attributes['军力'] < 30:
            crises.append("边军哗变风险")
        if self.imperial_stats['国库'] < 30:
            crises.append("财政破产危机")
        if self.inner_state['疲惫度'] > 70:
            crises.append("决策疲劳导致失误")
        if self.institutional_crisis > 70:
            crises.append("制度性危机：改革阻力极大")
        return crises
    
